# 1. startproject
build {{ outputdir }}/.startproject: startproject

# 2. startapp
build {{ outputdir }}/.startapp: startapp {{ outputdir }}/.startproject

# 3. installapp export
build {{ outputdir }}/.installapp_export: installapp_export {{ outputdir }}/.startapp

# 4. installapp replace
build {{ outputdir }}/.installapp_replace: installapp_replace {{ outputdir }}/.installapp_export

# 5. installapp rest_framework
build {{ outputdir }}/.installapp_rest: installapp_pkg {{ outputdir }}/.installapp_replace
  pkg = rest_framework

# 6. installapp django_extensions
build {{ outputdir }}/.installapp_ext: installapp_pkg {{ outputdir }}/.installapp_rest
  pkg = django_extensions

# 7. installapp myapp
build {{ outputdir }}/.installapp_myapp: installapp_pkg {{ outputdir }}/.installapp_ext
  pkg = {{ app }}

# 8. mkdir 群
build {{ outputdir }}/.mkdir_specs: mkdir {{ outputdir }}/.installapp_myapp
  dir = {{ outputdir }}/specs

build {{ outputdir }}/.mkdir_models: mkdir {{ outputdir }}/.installapp_myapp
  dir = {{ outputdir }}/{{ app }}/models

build {{ outputdir }}/.mkdir_views: mkdir {{ outputdir }}/.installapp_myapp
  dir = {{ outputdir }}/{{ app }}/views

build {{ outputdir }}/.mkdir_serializers: mkdir {{ outputdir }}/.installapp_myapp
  dir = {{ outputdir }}/{{ app }}/serializers

build {{ outputdir }}/.mkdir_schema: mkdir {{ outputdir }}/.installapp_myapp
  dir = {{ outputdir }}/schema

build {{ outputdir }}/.mkdir_tests: mkdir {{ outputdir }}/.installapp_myapp
  dir = tests/data

# 9. allowed_hosts export
build {{ outputdir }}/.allowed_hosts_export: allowed_hosts_export {{ outputdir }}/.mkdir_schema

# 10. allowed_hosts write
build {{ outputdir }}/.allowed_hosts_write: allowed_hosts_write {{ outputdir }}/.allowed_hosts_export

# 11. allowed_hosts import
build {{ outputdir }}/.allowed_hosts_import: allowed_hosts_import {{ outputdir }}/.allowed_hosts_write

# 12. urls.py patch
build {{ outputdir }}/.patch_urls: patch_urls

build init: phony {{ outputdir }}/.startproject {{ outputdir }}/.startapp {{ outputdir }}/.installapp_export {{ outputdir }}/.installapp_replace {{ outputdir }}/.installapp_rest {{ outputdir }}/.installapp_ext {{ outputdir }}/.installapp_myapp {{ outputdir }}/.mkdir_specs {{ outputdir }}/.mkdir_models {{ outputdir }}/.mkdir_views {{ outputdir }}/.mkdir_serializers {{ outputdir }}/.mkdir_schema {{ outputdir }}/.mkdir_tests {{ outputdir }}/.allowed_hosts_export {{ outputdir }}/.allowed_hosts_write {{ outputdir }}/.allowed_hosts_import {{ outputdir }}/.patch_urls

build mclean: mclean
