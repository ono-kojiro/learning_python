def _rand_str(prefix, length=8):
    s = "".join(random.choices(string.hexdigits.lower(), k=length))
    return f"{prefix}-{s}"


def _gen_dummy_value(fname, fdef):
    ftype = fdef["type"]

    if ftype == "CharField":
        max_len = fdef.get("max_length", 20)
        base = fname.upper()
        return _rand_str(base[:10], min(8, max_len))

    if ftype == "TextField":
        return f"{fname} text"

    if ftype == "IntegerField":
        return 1

    if ftype == "FloatField":
        return 1.0

    if ftype == "BooleanField":
        return True

    if ftype == "JSONField":
        return []

    if ftype == "DateTimeField":
        return datetime.datetime.now().isoformat()

    return None


def _gen_body(model_name, fields_def, fk_values=None):
    if fk_values is None:
        fk_values = {}

    if debug:
        print(f"[DEBUG] _gen_body model={model_name}")
        print(f"[DEBUG] fields_def={fields_def}")
        print(f"[DEBUG] fk_values={fk_values}")

    body = {}

    for fname, fdef in fields_def.items():
        ftype = fdef["type"]

        # --- ForeignKey / OneToOneField ---
        if ftype in ("ForeignKey", "OneToOneField"):
            # ★ 正しい汎用ロジック：フィールド名ではなく "to" を使う
            target_model = fdef["to"].lower()
            body[fname] = fk_values.get(target_model)

            if debug:
                print(f"[DEBUG] FK field={fname}, to={target_model}, value={body[fname]}")

        # --- ManyToManyField ---
        elif ftype == "ManyToManyField":
            target_model = fdef["to"].lower()
            v = fk_values.get(target_model)

            if v is None:
                body[fname] = []
            elif isinstance(v, list):
                body[fname] = v
            else:
                body[fname] = [v]

            if debug:
                print(f"[DEBUG] M2M field={fname}, to={target_model}, value={body[fname]}")

        # --- Normal fields ---
        else:
            body[fname] = _gen_dummy_value(fname, fdef)

            if debug:
                print(f"[DEBUG] Normal field={fname}, value={body[fname]}")

    if debug:
        print(f"[DEBUG] generated body={body}")

    return body

def _create_fk_objects(configs, fields):
    fk_values = {}

    print("\n=== DEBUG: ENTER _create_fk_objects for", model, "===")

    # schema.json を読む
    with open("../work/schema/schema.json", "r", encoding="utf-8") as fp:
        schema = json.load(fp)

    deps = schema["dependencies"].get(model, [])
    print("DEBUG: deps =", deps)

    load_order = schema["load_order"]
    print("DEBUG: load_order =", load_order)

    # Borrow の依存モデル展開
    expanded = []
    for d in deps:
        expanded.append(d)
        sub = schema["dependencies"].get(d, [])
        expanded.extend(sub)

    print("DEBUG: expanded deps =", expanded)

    fk_create_order = [m for m in load_order if m in expanded]
    print("DEBUG: fk_create_order =", fk_create_order)

    # 依存モデルを順番に作成
    for target in fk_create_order:
        print("\n--- DEBUG: Creating FK model:", target, "---")

        with open(f"../work/specs/{target.lower()}.json", "r", encoding="utf-8") as fp:
            ref = json.load(fp)

        print("DEBUG: ref fields =", ref["fields"])

        tbody = {}
        for fname, fdef in ref["fields"].items():
            ftype = fdef["type"]

            if ftype in ("ForeignKey", "OneToOneField"):
                dep_model = fdef["to"].lower()
                tbody[fname] = fk_values.get(dep_model)
            else:
                tbody[fname] = _gen_dummy_value(fname, fdef)

        print("DEBUG: FK POST BODY =", tbody)

        res_fk = requests.post(
            configs["base_url"] + f"/api/{target.lower()}s/",
            json=tbody,
        )

        print("DEBUG: FK POST STATUS =", res_fk.status_code)
        print("DEBUG: FK POST RESPONSE =", res_fk.text)

        assert res_fk.status_code == 201

        fk_values[target.lower()] = res_fk.json()["id"]
        print("DEBUG: fk_values updated =", fk_values)

    print("=== DEBUG: EXIT _create_fk_objects ===\n")
    return fk_values

{% set deps = dependencies.get(model, []) %}
{% if deps %}
@pytest.mark.order(10)
{% else %}
@pytest.mark.order(4)
{% endif %}
def test_delete_{{ model_lower }}(configs):
    base = configs["base_url"]

    fk_values = _create_fk_objects(configs, fields)

    item = _gen_body(model, fields, fk_values)

    for fname, fdef in fields.items():
        if fdef["type"] in ("ForeignKey", "OneToOneField", "ManyToManyField"):
            if fname in fk_values:
                item[fname] = fk_values[fname]

    res = requests.post(base + "/api/{{ model_lower }}s/", json=item)
    assert res.status_code == 201

    obj_id = res.json()["id"]

    del_res = requests.delete(base + f"/api/{{ model_lower }}s/{obj_id}/")
    assert del_res.status_code in (200, 204)

    get_res = requests.get(base + f"/api/{{ model_lower }}s/{obj_id}/")
    assert get_res.status_code == 404
