from django.apps import apps
from rest_framework import viewsets
from django_filters.rest_framework import DjangoFilterBackend

class {{ model }}ViewSet(viewsets.ModelViewSet):

    queryset = apps.get_model('myapp', '{{ model }}').objects.all()

    from myapp.serializers.{{ model_lower }}_serializer import {{ model }}Serializer
    serializer_class = {{ model }}Serializer

    {%- if pk_field %}
    filter_backends = [DjangoFilterBackend]
    filterset_fields = ["{{ pk_field }}"]
    {%- endif %}

    # ★ depth を GET パラメータで動的に変更する
    def get_serializer(self, *args, **kwargs):
        # depth=? が指定されていれば使う。なければ 1。
        try:
            depth = int(self.request.query_params.get("depth", 1))
        except ValueError:
            depth = 1

        serializer_class = self.get_serializer_class()

        # ★ Meta.depth を後から動的に差し替える
        class DynamicSerializer(serializer_class):
            class Meta(serializer_class.Meta):
                pass

        # ★ ここで depth を代入する（これが正しい）
        setattr(DynamicSerializer.Meta, "depth", depth)

        kwargs["context"] = self.get_serializer_context()
        return DynamicSerializer(*args, **kwargs)

